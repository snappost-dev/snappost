{
  "name": "snappost-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "embed": "node scripts/embed-templates.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create snappost-provisioning",
    "db:migrate": "wrangler d1 execute snappost-provisioning --remote --file=./src/db/schema.sql",
    "smoke": "bash scripts/smoke-api.sh",
    "r2:create": "wrangler r2 bucket create snappost-media"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/bcryptjs": "^2.4.6",
    "wrangler": "^3.28.0"
  }
}
