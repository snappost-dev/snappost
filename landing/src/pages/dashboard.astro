---
import Base from '../layouts/Base.astro';

/** CNAME “Name / Host” alanı için basit ipucu (çok parçalı TLD’lerde %100 doğru olmayabilir). */
function getCnameDnsHint(hostname: string): {
  nameField: string;
  nameDetail: string;
  apexWarning?: string;
} {
  const h = hostname.trim().toLowerCase().replace(/\.$/, '');
  if (!h) {
    return {
      nameField: '—',
      nameDetail: 'Use the hostname you registered above.',
    };
  }
  const parts = h.split('.').filter(Boolean);
  if (parts.length === 2) {
    return {
      nameField: '@',
      nameDetail:
        'Root domain (apex): in Cloudflare DNS choose Type CNAME and set Name to @. Some panels use a blank name or @ for the root.',
      apexWarning:
        'A few DNS providers do not allow a plain CNAME at the apex; if so, point the domain to Cloudflare nameservers or use their ALIAS/ANAME option.',
    };
  }
  const leaf = parts[0];
  return {
    nameField: leaf,
    nameDetail: `Subdomain: in Name / Host / Subdomain, enter only “${leaf}” (not the full “${h}”), unless your provider asks for the full hostname.`,
  };
}

const API_URL =
  Astro.locals.runtime.env.API_URL || import.meta.env.API_URL || 'http://localhost:8787';
const token = Astro.cookies.get('auth_token')?.value;

if (!token) {
  return Astro.redirect('/login');
}

// Verify token + get user
let user: any = null;
let sites: any[] = [];
let provisionError = '';
let provisionSuccess = '';
let domainFieldError: { siteId: string; message: string } | null = null;
let domainSuccessMessage = '';
let deleteSiteError: { siteId: string; message: string } | null = null;
let deleteSiteSuccessMessage = '';

try {
  const meRes = await fetch(`${API_URL}/api/auth/me`, {
    headers: { Authorization: `Bearer ${token}` },
  });
  if (!meRes.ok) {
    Astro.cookies.delete('auth_token', { path: '/' });
    return Astro.redirect('/login');
  }
  const meData = await meRes.json();
  user = meData.user;
} catch {
  return Astro.redirect('/login');
}

// Handle provision form
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action')?.toString();

  if (action === 'provision') {
    const siteName = form.get('site_name')?.toString().trim().toLowerCase() ?? '';
    if (!siteName) {
      provisionError = 'Site name required';
    } else {
      try {
        const res = await fetch(`${API_URL}/api/provision`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({ site_name: siteName }),
        });
        const data = await res.json();
        if (!res.ok) {
          const base = data.error || 'Provisioning failed';
          provisionError = data.detail ? `${base}: ${data.detail}` : base;
        } else {
          provisionSuccess = `Blog "${siteName}" created!`;
        }
      } catch {
        provisionError = 'Could not connect to server';
      }
    }
  } else if (action === 'connect_domain') {
    const siteId = form.get('site_id')?.toString();
    const domain = form.get('custom_domain')?.toString()?.trim();
    if (!siteId || !domain) {
      domainFieldError = { siteId: siteId || '', message: 'Domain required' };
    } else {
      try {
        const res = await fetch(`${API_URL}/api/sites/${siteId}/domain`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({ domain }),
        });
        const data = await res.json();
        if (!res.ok) {
          domainFieldError = {
            siteId,
            message: data.detail ? `${data.error}: ${data.detail}` : data.error || 'Request failed',
          };
        } else {
          domainSuccessMessage =
            'Custom domain registered at Cloudflare. Add the CNAME below. DNS and SSL can take 24–48 hours.';
        }
      } catch {
        domainFieldError = { siteId, message: 'Could not connect to server' };
      }
    }
  } else if (action === 'remove_domain') {
    const siteId = form.get('site_id')?.toString();
    if (!siteId) {
      domainFieldError = { siteId: '', message: 'Missing site' };
    } else {
      try {
        const res = await fetch(`${API_URL}/api/sites/${siteId}/domain`, {
          method: 'DELETE',
          headers: { Authorization: `Bearer ${token}` },
        });
        const data = await res.json();
        if (!res.ok) {
          domainFieldError = {
            siteId,
            message: data.detail ? `${data.error}: ${data.detail}` : data.error || 'Remove failed',
          };
        } else {
          domainSuccessMessage = 'Custom domain removed.';
        }
      } catch {
        domainFieldError = { siteId, message: 'Could not connect to server' };
      }
    }
  } else if (action === 'delete_site') {
    const siteId = form.get('site_id')?.toString();
    if (!siteId) {
      deleteSiteError = { siteId: '', message: 'Missing site' };
    } else {
      try {
        const res = await fetch(`${API_URL}/api/sites/${siteId}`, {
          method: 'DELETE',
          headers: { Authorization: `Bearer ${token}` },
        });
        const data = await res.json();
        if (!res.ok) {
          deleteSiteError = {
            siteId,
            message: data.detail ? `${data.error}: ${data.detail}` : data.error || 'Delete failed',
          };
        } else {
          const w = data.warnings;
          deleteSiteSuccessMessage =
            Array.isArray(w) && w.length > 0
              ? `Blog removed. Note: ${w.join(' ')}`
              : 'Blog removed from your account. Cloudflare projects and tenant database were deleted where possible.';
        }
      } catch {
        deleteSiteError = { siteId, message: 'Could not connect to server' };
      }
    }
  }

  if (action === 'logout') {
    Astro.cookies.delete('auth_token', { path: '/' });
    return Astro.redirect('/');
  }
}

// Fetch sites
try {
  const sitesRes = await fetch(`${API_URL}/api/sites`, {
    headers: { Authorization: `Bearer ${token}` },
  });
  if (sitesRes.ok) {
    const sitesData = await sitesRes.json();
    sites = sitesData.sites || [];
  }
} catch {}
---

<Base title="Dashboard">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-gray-500 text-sm">{user.email}</p>
      </div>
      <form method="POST">
        <input type="hidden" name="action" value="logout" />
        <button type="submit" class="text-gray-500 hover:text-gray-700 text-sm">Log out</button>
      </form>
    </div>

    <!-- Provision -->
    {provisionError && (
      <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{provisionError}</div>
    )}
    {provisionSuccess && (
      <div class="bg-green-50 text-green-700 px-4 py-3 rounded-lg mb-4 text-sm">{provisionSuccess}</div>
    )}
    {domainSuccessMessage && (
      <div class="bg-green-50 text-green-800 px-4 py-3 rounded-lg mb-4 text-sm border border-green-200">
        {domainSuccessMessage}
      </div>
    )}
    {deleteSiteSuccessMessage && (
      <div class="bg-green-50 text-green-800 px-4 py-3 rounded-lg mb-4 text-sm border border-green-200">
        {deleteSiteSuccessMessage}
      </div>
    )}
    {deleteSiteError && (
      <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">
        {deleteSiteError.message}
      </div>
    )}

    <div class="bg-white border border-gray-200 rounded-xl p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4">Create New Blog</h2>
      <form method="POST" class="flex gap-3">
        <input type="hidden" name="action" value="provision" />
        <input
          type="text" name="site_name" required
          pattern="[a-z0-9-]+"
          class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
          placeholder="my-awesome-blog (lowercase, hyphens only)"
        />
        <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition whitespace-nowrap">
          Create Blog
        </button>
      </form>
      <p class="text-xs text-gray-400 mt-2">This takes ~15 seconds. A D1 database, blog, and dashboard will be created.</p>
    </div>

    <!-- Sites -->
    <h2 class="text-lg font-semibold mb-4">Your Blogs ({sites.length})</h2>

    {sites.length === 0 ? (
      <div class="bg-white border border-gray-200 rounded-xl p-12 text-center">
        <div class="text-5xl mb-4">📝</div>
        <h3 class="text-lg font-semibold mb-1">No blogs yet</h3>
        <p class="text-gray-500 text-sm">Create your first blog above to get started</p>
      </div>
    ) : (
      <div class="space-y-4">
        {sites.map((site: any) => {
          const siteKey = String(site.id);
          const cnameTarget = site.shell_project_name
            ? `${site.shell_project_name}.pages.dev`
            : '';
          const dnsHint = site.custom_domain ? getCnameDnsHint(String(site.custom_domain)) : null;
          return (
          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <div class="flex justify-between items-start gap-4">
              <div class="min-w-0 flex-1">
                <h3 class="text-lg font-semibold mb-2">{site.site_name}</h3>
                <div class="space-y-1.5 text-sm">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-gray-500 w-20 shrink-0">Blog</span>
                    <a href={site.shell_url} target="_blank" class="text-blue-600 hover:underline break-all">{site.shell_url}</a>
                  </div>
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-gray-500 w-20 shrink-0">Dashboard</span>
                    <a href={site.dashboard_url} target="_blank" class="text-blue-600 hover:underline break-all">{site.dashboard_url}</a>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-gray-500 w-20">Status</span>
                    <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${
                      site.status === 'active' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800'
                    }`}>{site.status}</span>
                  </div>
                </div>

                <div class="mt-4 pt-4 border-t border-gray-100">
                  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Custom domain (blog)</p>
                  {site.custom_domain ? (
                    <div class="space-y-2">
                      <div class="text-sm">
                        <span class="text-gray-500">Connected:</span>{' '}
                        <span class="font-mono text-gray-900">{site.custom_domain}</span>
                      </div>
                      {cnameTarget && dnsHint && (
                        <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 text-xs text-slate-700 space-y-3">
                          <p class="font-semibold text-slate-800">DNS: add this at your registrar or DNS host</p>
                          <p class="text-slate-600 leading-relaxed">
                            Snappost cannot change DNS for you. Create one record so traffic for{' '}
                            <span class="font-mono bg-white px-1 rounded border border-slate-200">{site.custom_domain}</span>{' '}
                            reaches Cloudflare Pages.
                          </p>
                          <div class="overflow-x-auto rounded border border-slate-200 bg-white">
                            <table class="w-full text-left border-collapse">
                              <thead>
                                <tr class="border-b border-slate-200 bg-slate-100 text-slate-600">
                                  <th class="py-2 px-3 font-medium">Field</th>
                                  <th class="py-2 px-3 font-medium">Value</th>
                                </tr>
                              </thead>
                              <tbody class="text-slate-800">
                                <tr class="border-b border-slate-100">
                                  <td class="py-2 px-3 font-medium align-top">Type</td>
                                  <td class="py-2 px-3 font-mono">CNAME</td>
                                </tr>
                                <tr class="border-b border-slate-100">
                                  <td class="py-2 px-3 font-medium align-top">Name / Host</td>
                                  <td class="py-2 px-3">
                                    <span class="font-mono bg-slate-50 px-1.5 py-0.5 rounded">{dnsHint.nameField}</span>
                                    <p class="mt-1 text-slate-600 normal-case font-sans">{dnsHint.nameDetail}</p>
                                  </td>
                                </tr>
                                <tr class="border-b border-slate-100">
                                  <td class="py-2 px-3 font-medium align-top">Target / Value</td>
                                  <td class="py-2 px-3">
                                    <div class="flex flex-wrap items-center gap-2 font-mono bg-slate-50 px-2 py-1.5 rounded border border-slate-200">
                                      <span id={`cname-val-${siteKey}`}>{cnameTarget}</span>
                                      <button
                                        type="button"
                                        class="text-blue-600 hover:underline shrink-0 text-sm font-sans"
                                        data-cname-target={cnameTarget}
                                        onclick="navigator.clipboard.writeText(this.dataset.cnameTarget).then(() => { const b = this; const t = b.textContent; b.textContent = 'Copied!'; setTimeout(() => { b.textContent = t; }, 2000); })"
                                      >
                                        Copy
                                      </button>
                                    </div>
                                    <p class="mt-1 text-slate-600 font-sans">Paste this exact hostname as the CNAME target (same as Cloudflare Pages “target”).</p>
                                  </td>
                                </tr>
                                <tr>
                                  <td class="py-2 px-3 font-medium align-top">TTL</td>
                                  <td class="py-2 px-3">Auto / default</td>
                                </tr>
                              </tbody>
                            </table>
                          </div>
                          <p class="text-slate-600 leading-relaxed">
                            <strong class="text-slate-800">Cloudflare DNS:</strong> leave the orange cloud <strong>Proxied</strong> on unless your provider docs say otherwise. SSL is issued after the hostname validates; propagation can take <strong>24–48 hours</strong>.
                          </p>
                          {dnsHint.apexWarning && (
                            <p class="text-amber-800 bg-amber-50 border border-amber-200 rounded px-3 py-2 leading-relaxed">
                              <strong>Apex note:</strong> {dnsHint.apexWarning}
                            </p>
                          )}
                        </div>
                      )}
                      <form method="POST" class="inline">
                        <input type="hidden" name="action" value="remove_domain" />
                        <input type="hidden" name="site_id" value={siteKey} />
                        <button type="submit" class="text-sm text-red-600 hover:text-red-800 hover:underline">
                          Remove custom domain
                        </button>
                      </form>
                    </div>
                  ) : (
                    <div class="space-y-2 max-w-xl">
                      <div class="bg-slate-50 border border-slate-200 rounded-lg p-3 text-xs text-slate-600 leading-relaxed">
                        <p class="font-semibold text-slate-800 mb-1">What to enter</p>
                        <ul class="list-disc pl-4 space-y-1">
                          <li>
                            A hostname you control, e.g. <code class="bg-white px-1 rounded border border-slate-200">blog.example.com</code> or{' '}
                            <code class="bg-white px-1 rounded border border-slate-200">www.example.com</code> (no <code>https://</code>).
                          </li>
                          <li>After you connect, we show a <strong>CNAME</strong> table (Type, Name, Target) like Cloudflare’s DNS form — you copy values into your DNS panel.</li>
                          <li>Snappost does not log in to your registrar; DNS stays manual for this MVP.</li>
                        </ul>
                      </div>
                      <form method="POST" class="flex flex-col sm:flex-row gap-2 sm:items-end max-w-xl">
                        <input type="hidden" name="action" value="connect_domain" />
                        <input type="hidden" name="site_id" value={siteKey} />
                        <div class="flex-1 min-w-0">
                          <label class="sr-only" for={`domain-${siteKey}`}>Custom domain</label>
                          <input
                            id={`domain-${siteKey}`}
                            type="text"
                            name="custom_domain"
                            placeholder="blog.yourdomain.com"
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
                          />
                        </div>
                        <button
                          type="submit"
                          class="bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-900 transition whitespace-nowrap"
                        >
                          Connect domain
                        </button>
                      </form>
                    </div>
                  )}
                  {domainFieldError && domainFieldError.siteId === siteKey && (
                    <p class="text-red-600 text-xs mt-2">{domainFieldError.message}</p>
                  )}
                </div>
              </div>
              <div class="flex flex-col gap-2 shrink-0 items-stretch sm:items-end">
                <a
                  href={`${site.dashboard_url}/login?token=${site.access_token || ''}`}
                  target="_blank"
                  class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-800 transition text-center"
                >
                  Open Dashboard
                </a>
                <form
                  method="POST"
                  class="inline"
                  onsubmit="return confirm('Delete this blog permanently? Cloudflare Pages projects and the tenant database will be removed where possible. This cannot be undone.');"
                >
                  <input type="hidden" name="action" value="delete_site" />
                  <input type="hidden" name="site_id" value={siteKey} />
                  <button
                    type="submit"
                    class="w-full text-red-600 hover:text-red-800 text-sm font-medium py-1 border border-red-200 rounded-lg hover:bg-red-50 transition"
                  >
                    Delete blog
                  </button>
                </form>
              </div>
            </div>
          </div>
          );
        })}
      </div>
    )}
  </div>
</Base>
