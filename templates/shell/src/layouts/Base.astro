---
import SeoHead from '../components/SeoHead.astro';
import { loadBlogConfig } from '../lib/blog-config';
import { absoluteUrl, resolveSiteOrigin } from '../lib/site-url';

interface Props {
  title: string;
  description?: string;
  /** Varsayılan: mevcut istek pathname + search */
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  /** Aynı istekte ikinci config sorgusu önlemek için */
  config?: Record<string, string>;
}

const {
  title,
  description,
  canonicalPath,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  config: configProp,
} = Astro.props;

const config = configProp ?? (await loadBlogConfig(Astro.locals.runtime.env.DB));

const origin = resolveSiteOrigin(Astro.locals.runtime.env, Astro.url.href);
const path = canonicalPath ?? `${Astro.url.pathname}${Astro.url.search}`;
const canonicalHref = absoluteUrl(origin, path);
const rssHref = absoluteUrl(origin, '/rss.xml');

const metaDescRaw = (description ?? config.site_description ?? '').trim();
const metaDesc =
  metaDescRaw.length > 160 ? `${metaDescRaw.slice(0, 157)}…` : metaDescRaw;
---

<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={metaDesc} />
  <meta name="theme-color" content={config.theme_color} />
  <title>{title}</title>
  <SeoHead
    title={title}
    description={metaDesc}
    canonicalHref={canonicalHref}
    siteName={config.site_title}
    ogType={ogType}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    rssHref={rssHref}
  />
</head>
<body class="bg-gray-50 text-gray-900">
  <header class="bg-white border-b sticky top-0 z-10">
    <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
      <a href="/" class="text-xl font-bold">{config.site_title}</a>
      <nav class="flex gap-6">
        <a href="/" class="hover:text-blue-600">Home</a>
        <a href="/blog" class="hover:text-blue-600">Blog</a>
      </nav>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <slot />
  </main>

  <footer class="text-center py-8 text-gray-600 text-sm">
    <p>© {new Date().getFullYear()} {config.author_name}</p>
  </footer>
</body>
</html>
